# Copy to .env.local and fill in from your Supabase project settings
# (Project Settings → API). Same values go into Vercel.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Any long random string; signs driver session cookies.
# Generate one: openssl rand -base64 48
DRIVER_SESSION_SECRET=
