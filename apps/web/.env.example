# Copy to .env.local and fill in.

# Neon: use the POOLED connection string (the -pooler host) from the Neon
# console, including sslmode=require. Local dev: plain Postgres works too,
# e.g. postgres://postgres:postgres@localhost:5433/oasis
# SERVER-ONLY — never expose to the browser, never prefix with NEXT_PUBLIC_.
DATABASE_URL=

# Any long random string; signs driver and staff session cookies.
# Generate one: openssl rand -base64 48
SESSION_SECRET=
